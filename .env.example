# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (local or remote)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/goteamcrew

# Long random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# Set to "production" when running on VPS — enables static file serving,
# secure cookies, and startup env-var enforcement.
NODE_ENV=production

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the Express server listens on (default: 3000).
# Nginx should proxy to this port.
PORT=3000

# Your public domain (used for CORS / redirect URLs)
APP_ORIGIN=https://goteamcrew.com

# Google Cloud Storage (for crew photo uploads)
# Leave blank if you are using local disk storage instead.
GOOGLE_CLOUD_SERVICE_ACCOUNT_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# Google Maps (baked into the frontend build at build time — not needed at runtime)
# Only set this if you are rebuilding the frontend from source on the VPS.
VITE_GOOGLE_MAPS_API_KEY=
